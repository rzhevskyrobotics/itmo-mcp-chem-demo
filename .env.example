# ── Пример конфигурации. Скопируйте в .env и заполните своими значениями. ──
# Файл .env в репозиторий НЕ коммитится (см. .gitignore).

# Сеть приложения
APP_HOST=127.0.0.1          # 0.0.0.0 — слушать все интерфейсы (для локальной отладки)
APP_PORT=8080               # порт backend; согласуйте с proxy_pass в nginx
PUBLIC_URL=http://localhost:8080   # публичный HTTPS-адрес (нужен OpenAI для доступа к /mcp)

# Вход в веб-интерфейс.
# ВАЖНО: в любом сетевом развёртывании ОБЯЗАТЕЛЬНО задайте свой пароль.
# Если не задать — приложение стартует с демо-паролем и выведет предупреждение.
AUTH_USER=demo
AUTH_PASSWORD=ЗАДАЙТЕ_СВОЙ_ПАРОЛЬ

# Привилегированный внутренний токен (источник 'mcp' в adapter-API).
# Если не задать — генерируется случайный токен на время жизни процесса.
# Задайте постоянное случайное значение, если нужен стабильный внешний доступ.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=

# Фаза 3 — «живые» ИИ-агенты через OpenAI Responses API.
# Без ключа система работает в офлайн-режиме (правдоподобные шаблоны) — это штатно.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Необязательная Bearer-защита MCP-эндпоинта (/mcp). Пусто — защита отключена (демо).
MCP_CONNECTOR_TOKEN=

# Тик симуляции эмулятора, мс
TICK_MS=500
